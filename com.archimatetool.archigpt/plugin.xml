<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
   <extension
         point="org.eclipse.ui.views">
      <category
            id="com.archimatetool.archigpt"
            name="ArchiGPT">
      </category>
      <view
            category="com.archimatetool.archigpt"
            class="com.archimatetool.archigpt.ArchiGPTView"
            id="com.archimatetool.archigpt.view"
            name="ArchiGPT"
            restorable="true">
      </view>
   </extension>
   <!-- Menu: add "ArchiGPT" to main menu bar and to Help/Tools/Window where available -->
   <extension
         point="org.eclipse.ui.menus">
      <!-- Top-level ArchiGPT menu in main menu bar (visible in most RCP products including Archi) -->
      <menuContribution
            locationURI="menu:org.eclipse.ui.main.menu?after=additions">
         <menu
               id="com.archimatetool.archigpt.menu"
               label="ArchiGPT">
            <command
                  commandId="org.eclipse.ui.views.showView"
                  id="com.archimatetool.archigpt.showView.main"
                  label="Show ArchiGPT View"
                  style="push">
               <parameter
                     name="org.eclipse.ui.views.showView.viewId"
                     value="com.archimatetool.archigpt.view">
               </parameter>
            </command>
         </menu>
      </menuContribution>
      <menuContribution
            locationURI="menu:help?after=additions">
         <command
               commandId="org.eclipse.ui.views.showView"
               id="com.archimatetool.archigpt.showView.help"
               label="Show ArchiGPT View"
               style="push">
            <parameter
                  name="org.eclipse.ui.views.showView.viewId"
                  value="com.archimatetool.archigpt.view">
            </parameter>
         </command>
      </menuContribution>
      <menuContribution
            locationURI="menu:tools?after=additions">
         <command
               commandId="org.eclipse.ui.views.showView"
               id="com.archimatetool.archigpt.showView.tools"
               label="ArchiGPT"
               style="push">
            <parameter
                  name="org.eclipse.ui.views.showView.viewId"
                  value="com.archimatetool.archigpt.view">
            </parameter>
         </command>
      </menuContribution>
      <menuContribution
            locationURI="menu:window?after=additions">
         <command
               commandId="org.eclipse.ui.views.showView"
               id="com.archimatetool.archigpt.showView.window"
               label="ArchiGPT"
               style="push">
            <parameter
                  name="org.eclipse.ui.views.showView.viewId"
                  value="com.archimatetool.archigpt.view">
            </parameter>
         </command>
      </menuContribution>
      <menuContribution
            locationURI="menu:com.archimatetool.archigpt.menu?after=additions">
         <command
               commandId="com.archimatetool.archigpt.openPreferences"
               id="com.archimatetool.archigpt.openPreferences.menu"
               label="ArchiGPT Preferences…"
               style="push">
         </command>
      </menuContribution>
   </extension>
   <extension
         point="org.eclipse.ui.preferencePages">
      <page
            id="com.archimatetool.archigpt.preferences"
            name="ArchiGPT"
            class="com.archimatetool.archigpt.preferences.ArchiGPTPreferencePage">
      </page>
   </extension>
   <extension
         point="org.eclipse.ui.commands">
      <command
            id="com.archimatetool.archigpt.openPreferences"
            name="ArchiGPT Preferences">
      </command>
   </extension>
   <extension
         point="org.eclipse.ui.handlers">
      <handler
            class="com.archimatetool.archigpt.handlers.OpenArchiGPTPreferencesHandler"
            commandId="com.archimatetool.archigpt.openPreferences">
      </handler>
   </extension>
</plugin>
